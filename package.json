{
  "name": "opencode-doubao-tts",
  "version": "1.0.0",
  "description": "语音输入插件 - 按住浮窗说话，文字直接输入到OpenCode",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node tests/stt/stt-runner.js",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:stt": "node tests/stt/stt-runner.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:stt",
    "test:generate-fixtures": "node tests/stt/generate-fixtures.js",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "opencode",
    "plugin",
    "voice",
    "stt",
    "speech"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  }
}
